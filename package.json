{
  "name": "@oliveryasuna/m2m",
  "version": "2.0.0",
  "description": "Convert Markdown to HTML for pasting into Medium (or any rich text editor).",
  "keywords": [
    "markdown",
    "medium",
    "html",
    "cli",
    "bun",
    "node",
    "deno"
  ],
  "author": "Oliver Yasuna (https://github.com/oliveryasuna)",
  "contributors": [
    {
      "name": "Oliver Yasuna",
      "url": "https://github.com/oliveryasuna"
    },
    {
      "name": "Steve Todorov",
      "url": "https://github.com/steve-todorov"
    }
  ],
  "license": "MIT",
  "homepage": "https://github.com/oliveryasuna/markdown-to-medium",
  "bugs": "https://github.com/oliveryasuna/markdown-to-medium/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oliveryasuna/markdown-to-medium.git"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "bin": {
    "m2m": "dist/index.js"
  },
  "files": ["dist/index.js", "README.md", "LICENSE"],
  "scripts": {
    "prepublishOnly": "bun run build:npm",
    "build:npm": "bun build ./index.ts --target=node --external marked --outfile dist/index.js",
    "build": "bun build ./index.ts --compile --minify --sourcemap --outfile dist/m2m",
    "build:all": "bun run build:linux-x64 && bun run build:linux-arm64 && bun run build:darwin-x64 && bun run build:darwin-arm64 && bun run build:windows-x64",
    "build:linux-x64": "bun build ./index.ts --compile --minify --sourcemap --target=bun-linux-x64 --outfile dist/m2m-linux-x64",
    "build:linux-arm64": "bun build ./index.ts --compile --minify --sourcemap --target=bun-linux-arm64 --outfile dist/m2m-linux-arm64",
    "build:darwin-x64": "bun build ./index.ts --compile --minify --sourcemap --target=bun-darwin-x64 --outfile dist/m2m-darwin-x64",
    "build:darwin-arm64": "bun build ./index.ts --compile --minify --sourcemap --target=bun-darwin-arm64 --outfile dist/m2m-darwin-arm64",
    "build:windows-x64": "bun build ./index.ts --compile --minify --sourcemap --target=bun-windows-x64 --outfile dist/m2m-windows-x64.exe"
  },
  "dependencies": {
    "marked": "18.0.3"
  },
  "devDependencies": {
    "@types/bun": "1.3.13",
    "typescript": "5.9.3"
  }
}
